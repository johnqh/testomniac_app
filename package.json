{
  "name": "@sudobility/testomniac_app",
  "description": "Testomniac web application - React + Vite",
  "private": true,
  "license": "BUSL-1.1",
  "version": "1.0.86",
  "type": "module",
  "scripts": {
    "dev": "bun run process:static && vite",
    "build": "bun run process:static && tsc -b && vite build",
    "process:static": "tsx scripts/process-static-files.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "localize": "SCRIPT=$(mktemp) && curl -fsSL https://raw.githubusercontent.com/johnqh/workflows/main/scripts/localize_batch.cjs -o $SCRIPT && node $SCRIPT ./public/locales https://api.whisperly.dev/api/v1/translate/jie9cytr/starter --word-limit 40 && rm -f $SCRIPT && prettier . --write",
    "localized": "node scripts/localization_verify.cjs",
    "verify": "bun run typecheck && bun run lint && bun run format:check"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@sudobility/auth-components": "^1.0.10",
    "@sudobility/auth_lib": "^0.0.70",
    "@sudobility/building_blocks": "^0.0.227",
    "@sudobility/components": "^5.0.62",
    "@sudobility/design": "^1.1.29",
    "@sudobility/devops-components": "^2.0.19",
    "@sudobility/di": "^1.5.52",
    "@sudobility/di_web": "^0.1.173",
    "@sudobility/entity_client": "^0.0.34",
    "@sudobility/entity_pages": "^0.0.102",
    "@sudobility/seo_lib": "^0.0.10",
    "@sudobility/subscription-components": "^1.0.31",
    "@sudobility/subscription_lib": "^0.0.40",
    "@sudobility/testomniac_client": "^0.0.33",
    "@sudobility/testomniac_lib": "^0.0.33",
    "@sudobility/testomniac_types": "^0.0.28",
    "@sudobility/types": "^1.9.61",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "firebase": "^12.4.0",
    "i18next": "^25.8.7",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.511.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/dagre": "^0.7.54",
    "@types/node": "^24.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "postcss": "^8.4.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/johnqh/entitystarter_app.git"
  }
}
