# ============================================================================
# FIREBASE CONFIGURATION
# ============================================================================

# Firebase Web API key (found in Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=

# Firebase Auth domain (e.g., your-project.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=

# Firebase project ID
VITE_FIREBASE_PROJECT_ID=

# Firebase Storage bucket (e.g., your-project.firebasestorage.app)
VITE_FIREBASE_STORAGE_BUCKET=

# Firebase Cloud Messaging sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Firebase app ID
VITE_FIREBASE_APP_ID=

# Firebase Analytics measurement ID (optional, e.g., G-XXXXXXXXXX)
VITE_FIREBASE_MEASUREMENT_ID=

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Backend API URL (testomniac_api server)
VITE_API_URL=http://localhost:8027

# ============================================================================
# BRANDING CONFIGURATION
# ============================================================================

# App name displayed in TopBar, login page, and SEO meta tags
VITE_APP_NAME=

# Domain used for SEO base URL and OG image paths (e.g., myapp.com)
VITE_APP_DOMAIN=

# Company name shown in Footer and SEO config
VITE_COMPANY_NAME=

# Support email shown in SEO config
VITE_SUPPORT_EMAIL=

# Twitter/X handle for SEO twitter:site meta tag (without @)
VITE_TWITTER_HANDLE=

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable test/dev mode in SudobilityAppWithFirebaseAuth (true/false)
VITE_DEV_MODE=false

# Show floating performance monitor panel (true/false)
VITE_SHOW_PERFORMANCE_MONITOR=false
